{
    "name": "daljo25/filament-dependency-manager",
    "description": "A Filament plugin to inspect Composer and NPM dependencies, check available updates, and provide suggested upgrade commands.",
    "keywords": [
        "daljo25",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-dependency-manager"
    ],
    "homepage": "https://github.com/daljo25/filament-dependency-manager",
    "support": {
        "issues": "https://github.com/daljo25/filament-dependency-manager/issues",
        "source": "https://github.com/daljo25/filament-dependency-manager"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Daljomar Morillo",
            "email": "camalion007@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "calebporzio/sushi": "^2.5",
        "filament/filament": "^3.2",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^7.0|^8.0|^9.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Daljo25\\FilamentDependencyManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Daljo25\\FilamentDependencyManager\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test": "pest",
        "test:lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Daljo25\\FilamentDependencyManager\\FilamentDependencyManagerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}